{
    "name": "portfolio-backend",
    "version": "1.0.0",
    "type": "module",
    "description": "",
    "main": "index.js",
    "scripts": {
        "dev": "tsx watch src/index.ts",
        "build": "tsc",
        "start": "node dist/index.js",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "format": "prettier . --check",
        "format:fix": "prettier . --write",
        "lines": "cloc . --exclude-dir=dist,node_modules,.next --include-ext=ts,tsx --exclude-ext=d.ts,gen.ts",
        "lines:large": "cloc . --exclude-dir=dist,node_modules,.next --include-ext=ts,tsx --exclude-ext=d.ts,gen.ts --by-file --csv | awk -F, '$5 >= 500 {print $2, $5}'",
        "tree": "tree -I node_modules -I dist -I node_modules -I public"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "packageManager": "pnpm@10.27.0",
    "dependencies": {
        "cookie-parser": "^1.4.7",
        "cors": "^2.8.6",
        "dotenv": "^17.3.1",
        "express": "^5.2.1",
        "express-rate-limit": "^8.3.0",
        "helmet": "^8.1.0",
        "pg": "^8.20.0"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/cookie-parser": "^1.4.10",
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.6",
        "@types/pg": "^8.18.0",
        "prettier": "^3.8.1",
        "tsx": "^4.21.0",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.56.1"
    }
}
